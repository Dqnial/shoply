# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db-name>

# Secret used to sign JWT auth tokens — use a long random string
JWT_SECRET=change-me-to-a-long-random-string

# Port the unified server (API + frontend, see src/server.ts) listens on
PORT=5000

# The app's own public URL. Same-origin by default (frontend and API share
# this one port), so CORS/cookie SameSite checks rarely come into play —
# only matters if you split the frontend out to a different origin.
FRONTEND_URL=http://localhost:5000

# development | production — controls stack traces in error responses
NODE_ENV=development
