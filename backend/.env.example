# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db-name>

# Secret used to sign JWT auth tokens — use a long random string
JWT_SECRET=change-me-to-a-long-random-string

# Port the API server listens on
PORT=5000

# Origin allowed by CORS (the frontend's URL)
FRONTEND_URL=http://localhost:3000

# development | production — controls stack traces in error responses
NODE_ENV=development
